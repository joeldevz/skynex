{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "orchestrator": {
      "description": "Orchestrator — pure coordination agent. Delegates all work to sub-agents. NEVER writes code. Reads a few files to decide, launches parallel sub-agents, synthesizes results.",
      "mode": "all",
      "prompt": "{file:./agents/orchestrator.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "read": true,
        "write": true,
        "glob": true,
        "grep": true,
        "neurox_session_start": true,
        "neurox_context": true,
        "neurox_recall": true,
        "neurox_save": true,
        "neurox_update": true,
        "neurox_session_end": true
      },
      "model": "anthropic/claude-sonnet-4-6"
    },
    "linear-orchestrator": {
      "description": "Linear-driven orchestrator — drives a single Linear issue end-to-end with strict TDD and human gates. Reads/clarifies the issue, writes 6 phase comments, spawns parallel sub-agents to write failing tests (red), waits for explicit human validation, implements to green, and opens a PR. Never writes code itself.",
      "mode": "all",
      "prompt": "{file:./agents/linear-orchestrator.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "read": true,
        "write": true,
        "glob": true,
        "grep": true,
        "linear*": true,
        "neurox_session_start": true,
        "neurox_context": true,
        "neurox_recall": true,
        "neurox_save": true,
        "neurox_update": true,
        "neurox_session_end": true
      },
      "model": "anthropic/claude-sonnet-4-6"
    },
    "advisor": {
      "description": "Senior strategic advisor for complex decisions. Pure thinking — no file tools.",
      "model": "anthropic/claude-opus-4-6",
      "mode": "subagent",
      "prompt": "{file:./agents/advisor.md}",
      "tools": {}
    },
    "coder": {
      "description": "Use when the orchestrator delegates one bounded coding task with execution-first focus.",
      "mode": "subagent",
      "model": "anthropic/claude-haiku-4-5",
      "prompt": "{file:./agents/coder.md}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true,
        "glob": true,
        "grep": true,
        "neurox_session_start": true,
        "neurox_context": true,
        "neurox_recall": true,
        "neurox_save": true,
        "neurox_update": true,
        "neurox_session_end": true,
        "advisor_consult": true
      }
    },

    "manager": {
      "description": "Project Manager Agent - reads PLAN.md, delegates one step at a time to coder, and enforces the human review loop",
      "mode": "subagent",
      "prompt": "{file:./agents/manager.md}",
      "tools": {
        "bash": true,
        "read": true,
        "neurox_session_start": true,
        "neurox_context": true,
        "neurox_recall": true,
        "neurox_save": true,
        "neurox_update": true,
        "neurox_session_end": true,
        "advisor_consult": true
      },
      "model": "anthropic/claude-haiku-4-5"
    },
    "tech-planner": {
      "model": "anthropic/claude-sonnet-4-6",
      "description": "Technical Planner - reads the task (or an existing SPEC), does deep codebase discovery, and produces a prescriptive PLAN.md where every step has a mandatory How section with exact file paths, signatures, and snippets",
      "mode": "subagent",
      "prompt": "{file:./agents/tech-planner.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "read": true,
        "write": true,
        "neurox_session_start": true,
        "neurox_context": true,
        "neurox_recall": true,
        "neurox_save": true,
        "neurox_update": true,
        "neurox_session_end": true,
        "advisor_consult": true
      }
    },
    "verifier": {
      "description": "Use after each coder step to run lint, build, and tests on the modified files. Returns pass/fail with structured verifier_feedback.",
      "mode": "subagent",
      "prompt": "{file:./agents/verifier.md}",
      "tools": {
        "bash": true,
        "read": true,
        "glob": true,
        "grep": true
      },
      "model": "anthropic/claude-haiku-4-5"
    },
    "test-reviewer": {
      "model": "anthropic/claude-haiku-4-5",
      "description": "Use after plan completion to review test coherence and quality. Classifies each test file as SOUND, WEAK, or MISLEADING.",
      "mode": "subagent",
      "prompt": "{file:./agents/test-reviewer.md}",
      "tools": {
        "read": true,
        "glob": true,
        "grep": true
      }
    },
    "security": {
      "model": "anthropic/claude-haiku-4-5",
      "description": "Use as one of two parallel adversarial security judges. Finds vulnerabilities in injection, auth, data exposure, rate limiting, crypto, dependencies.",
      "mode": "subagent",
      "prompt": "{file:./agents/security.md}",
      "tools": {
        "read": true,
        "glob": true,
        "grep": true,
        "bash": true
      }
    },
    "skill-validator": {
      "model": "anthropic/claude-haiku-4-5",
      "description": "Skill Validator - validates implemented code against project skill registry at end of plan. Flags deviations from documented patterns, naming conventions, and architectural rules.",
      "mode": "subagent",
      "prompt": "{file:./agents/skill-validator.md}",
      "tools": {
        "read": true,
        "glob": true,
        "grep": true,
        "neurox_recall": true,
        "neurox_context": true
      }
    },
    "pr-reviewer": {
      "model": "anthropic/claude-sonnet-4-6",
      "description": "Adversarial PR review judge for a single 4R+1 dimension (Correctness/Risk/Readability/Reliability/Resilience). Launched in parallel by the orchestrator. Read-only.",
      "mode": "subagent",
      "prompt": "{file:./agents/pr-reviewer.md}",
      "tools": {
        "read": true,
        "glob": true,
        "grep": true,
        "neurox_recall": true,
        "neurox_context": true
      }
    }
  },
  "provider": {},
  "mcp": {
    "atlassian": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp"
    },
    "brevo": {
      "type": "remote",
      "url": "https://mcp.brevo.com/v1/brevo/mcp",
      "headers": {
        "Authorization": "Bearer ${BREVO_API_KEY}"
      },
      "enabled": true
    },
    "chrome-devtools": {
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@0.23.0"
      ],
      "enabled": true,
      "environment": {
        "CDP_URL": "http://localhost:9222",
        "CHROME_PATH": "/usr/bin/chromium"
      },
      "timeout": 30000,
      "type": "local"
    },
    "cloudflare-api": {
      "type": "remote",
      "url": "https://mcp.cloudflare.com/mcp"
    },
    "context7": {
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      },
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "exa": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp"
    },
    "figma": {
      "command": [
        "npx",
        "-y",
        "figma-developer-mcp@0.11.0",
        "--stdio"
      ],
      "enabled": true,
      "environment": {
        "DO_NOT_TRACK": "1",
        "FIGMA_API_KEY": "${FIGMA_API_KEY}",
        "FRAMELINK_TELEMETRY": "off"
      },
      "timeout": 15000,
      "type": "local"
    },
    "jina-mcp-server": {
      "type": "remote",
      "url": "https://mcp.jina.ai/v1"
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": true
    },
    "neurox": {
      "command": [
        "neurox",
        "mcp"
      ],
      "enabled": true,
      "type": "local"
    },
    "slack": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-slack"
      ],
      "environment": {
        "SLACK_BOT_TOKEN": "${SLACK_BOT_TOKEN}",
        "SLACK_TEAM_ID": "${SLACK_TEAM_ID}"
      },
      "enabled": true
    }
  },
  "plugin": [
    "opencode-anthropic-login-via-cli",
    "@ex-machina/opencode-anthropic-auth"
  ],
  "small_model": "anthropic/claude-haiku-4-5"
}
