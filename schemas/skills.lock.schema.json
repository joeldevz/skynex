{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skynex.dev/schemas/skills.lock.schema.json",
  "title": "Skynex Lock File",
  "description": "Resolved and installed state for skynex packages",
  "type": "object",
  "required": ["version", "generatedAt", "packages"],
  "properties": {
    "version": {
      "description": "Schema version",
      "const": 1
    },
    "generatedAt": {
      "type": "string",
      "description": "ISO 8601 timestamp of when the lock was generated",
      "format": "date-time"
    },
    "packages": {
      "type": "object",
      "description": "Installed package states",
      "additionalProperties": {
        "type": "object",
        "required": ["requestedVersion", "resolvedVersion", "commit", "repoUrl", "targets"],
        "properties": {
          "requestedVersion": {
            "type": "string",
            "description": "Version selector requested by user"
          },
          "resolvedVersion": {
            "type": "string",
            "description": "Resolved version (tag, branch name, or 'workspace')"
          },
          "resolvedRef": {
            "type": "string",
            "description": "Full git ref (e.g., refs/tags/v1.0.0)"
          },
          "commit": {
            "type": "string",
            "description": "Exact commit SHA",
            "pattern": "^[a-f0-9]{40}$"
          },
          "repoUrl": {
            "type": "string",
            "description": "Repository URL",
            "format": "uri"
          },
          "dirty": {
            "type": "boolean",
            "description": "Whether the workspace had uncommitted changes (workspace mode only)"
          },
          "targets": {
            "type": "object",
            "description": "Per-target installation state",
            "patternProperties": {
              "^(claude|opencode)$": {
                "type": "object",
                "required": ["status", "installedAt", "artifacts"],
                "properties": {
                  "status": {
                    "enum": ["installed", "unchanged"],
                    "description": "Installation status"
                  },
                  "installedAt": {
                    "type": "string",
                    "description": "ISO 8601 timestamp of installation",
                    "format": "date-time"
                  },
                  "artifacts": {
                    "type": "array",
                    "description": "Paths to installed artifacts",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "advisor": {
      "type": "object",
      "description": "Installed advisor configuration",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "model": {
          "type": "string"
        },
        "installedAt": {
          "type": "string",
          "description": "ISO 8601 timestamp of when advisor was configured"
        }
      }
    }
  }
}
