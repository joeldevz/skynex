{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skynex.dev/schemas/skills.config.schema.json",
  "title": "Skynex Configuration",
  "description": "User intent and defaults for skynex installations",
  "type": "object",
  "required": ["version", "defaults", "packages"],
  "properties": {
    "version": {
      "description": "Schema version",
      "const": 1
    },
    "defaults": {
      "type": "object",
      "description": "Default settings for interactive mode",
      "required": ["interactive", "targets"],
      "properties": {
        "interactive": {
          "type": "boolean",
          "description": "Whether to run in interactive mode by default"
        },
        "targets": {
          "type": "array",
          "description": "Default target environments",
          "items": {
            "enum": ["claude", "opencode"]
          },
          "uniqueItems": true
        }
      }
    },
    "packages": {
      "type": "object",
      "description": "Per-package configuration",
      "additionalProperties": {
        "type": "object",
        "required": ["version", "targets"],
        "properties": {
          "version": {
            "type": "string",
            "description": "Requested version selector"
          },
          "targets": {
            "type": "array",
            "description": "Target environments for this package",
            "items": {
              "enum": ["claude", "opencode"]
            },
            "uniqueItems": true
          }
        }
      }
    },
    "advisor": {
      "type": "object",
      "description": "Advisor strategy configuration — optional strategic escalation to a larger model",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether the advisor tool is available to worker agents",
          "default": false
        },
        "model": {
          "type": "string",
          "description": "Model to use for the advisor agent (e.g., anthropic/claude-opus-4-6, openai/gpt-4o)",
          "default": "anthropic/claude-opus-4-6"
        },
        "maxUses": {
          "type": "integer",
          "description": "Maximum advisor calls per session",
          "default": 3,
          "minimum": 1,
          "maximum": 10
        }
      }
    }
  }
}
